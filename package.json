{
  "name": "reputon",
  "version": "0.1.0",
  "private": true,
  "description": "Reputon — Universal On-Chain Reputation Layer powered by Genlayer Intelligent Contracts.",
  "license": "UNLICENSED",
  "workspaces": [
    "frontend",
    "backend",
    "packages/db"
  ],
  "scripts": {
    "env:check": "python3 scripts/env_check.py",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "infra:reset": "docker compose -f infra/docker-compose.yml down -v",
    "db:generate": "npm --workspace @reputon/db run generate",
    "db:migrate": "npm --workspace backend run migrate",
    "db:seed": "npm --workspace backend run seed",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build:frontend": "npm --workspace frontend run build",
    "build:backend": "npm --workspace backend run build",
    "typecheck": "npm --workspace frontend run typecheck && npm --workspace backend run typecheck",
    "test:backend": "npm --workspace backend run test",
    "test:frontend": "npm --workspace frontend run test",
    "test:contracts": "python3 -m unittest intelligent-contracts/tests/test_contracts.py -v",
    "test": "npm run test:backend && npm run test:frontend && npm run test:contracts"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3"
  }
}
