# =====================================================================
# Reputon — Environment variables template
# Copy this file to `.env` at the repo root. NEVER commit the real .env.
# Each workspace can also have its own .env.local that overrides.
# =====================================================================

# ============================== Postgres =============================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=reputon
POSTGRES_PASSWORD=reputon
POSTGRES_DB=reputon
DATABASE_URL=postgres://reputon:reputon@localhost:5432/reputon

# ================================ Redis ==============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ============================ MinIO (S3) =============================
MINIO_ROOT_USER=reputon
MINIO_ROOT_PASSWORD=reputonsecret
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=reputon
S3_SECRET_KEY=reputonsecret
S3_BUCKET=reputon-assets
S3_FORCE_PATH_STYLE=true

# ============================ Auth.js (v5) ===========================
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ------- Google OAuth (optional; sign-in works without it) ---------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ------- Email magic-link (SMTP). Leave empty to disable. -----------
AUTH_EMAIL_FROM=Reputon <no-reply@reputon.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================ Backend API ============================
BACKEND_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_RATE_LIMIT_PER_MIN=120

# ============================ Genlayer ===============================
NEXT_PUBLIC_GENLAYER_RPC_URL=https://studio.genlayer.com:8443/api
NEXT_PUBLIC_GENLAYER_CHAIN_ID=61999
GENLAYER_ACCOUNT_PRIVATE_KEY=
GENLAYER_ACCOUNT_ADDRESS=

# Filled in after Phase 4/5 deploys
NEXT_PUBLIC_REPUTON_CONTRACT_ADDRESS=
NEXT_PUBLIC_REPUTON_NFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_SYBIL_ORACLE_CONTRACT_ADDRESS=

# ============================ App config =============================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Reputon
NODE_ENV=development

# Optional, used by analyzer in later phases
GITHUB_TOKEN=
